@{
    ViewData["Title"] = "ChatApp Home";
}

<h1>Welcome to ChatApp!</h1>

<div>
    <label>Chat with User ID: </label>
    <input type="number" id="otherUserId" value="2" />
    <button onclick="loadMessages()">Load Messages</button>
</div>

<div id="messages" style="margin-top:20px; border:1px solid #ccc; padding:10px; height:300px; overflow-y:scroll;">
    <p>No messages loaded yet.</p>
</div>

<div style="margin-top:10px;">
    <input type="text" id="newMessage" placeholder="Type a message..." style="width:70%;" />
    <button onclick="sendMessage()">Send</button>
</div>

<script>
    const apiBase = '/api/Messages';

    async function loadMessages() {
        const userId = document.getElementById('otherUserId').value;
        const res = await fetch(`${apiBase}/direct/${userId}`, {
            headers: {
                'Authorization': 'Bearer ' + localStorage.getItem('token') // replace with your JWT if needed
            }
        });
        if (!res.ok) {
            alert('Failed to load messages. Make sure you are logged in.');
            return;
        }
        const data = await res.json();
        const container = document.getElementById('messages');
        container.innerHTML = '';
        if (data.length === 0) container.innerHTML = '<p>No messages yet.</p>';
        data.forEach(m => {
            const div = document.createElement('div');
            div.style.borderBottom = '1px solid #eee';
            div.style.marginBottom = '5px';
            div.innerHTML = `<strong>${m.senderName}:</strong> ${m.content} <small>${new Date(m.sentAt).toLocaleString()}</small>`;
            container.appendChild(div);
        });
    }

    async function sendMessage() {
        const userId = document.getElementById('otherUserId').value;
        const message = document.getElementById('newMessage').value;
        if (!message) return alert('Type a message first');

        const res = await fetch(`${apiBase}/direct/${userId}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': 'Bearer ' + localStorage.getItem('token')
            },
            body: JSON.stringify({ content: message })
        });

        if (res.ok) {
            document.getElementById('newMessage').value = '';
            loadMessages();
        } else {
            alert('Failed to send message.');
        }
    }

    // Optional: auto-load messages every 5 seconds
    setInterval(loadMessages, 5000);
</script>